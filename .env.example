# ============================================================================
# Supabase — variáveis públicas (podem ir pro frontend)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...sua-anon-key-aqui

# ============================================================================
# Supabase — variáveis SECRETAS (apenas backend / Edge Functions)
# NUNCA expor no frontend, NUNCA commitar no git
# ============================================================================
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-aqui-NUNCA-EXPOR

# ============================================================================
# Configuração do template (opcional)
# ============================================================================
# Se "true", criar uma empresa automaticamente quando o usuário fizer signup
# (o usuário vira owner dessa empresa).
# Se "false", o usuário precisa ser convidado para uma empresa existente.
TEMPLATE_AUTO_CREATE_COMPANY_ON_SIGNUP=true

# Tempo de expiração de convites (em horas). Padrão: 168 (7 dias)
TEMPLATE_INVITATION_EXPIRY_HOURS=168

# ============================================================================
# Email (para envio de convites via Edge Function)
# ============================================================================
# Usando Resend (https://resend.com) — recomendado pela facilidade
RESEND_API_KEY=re_...
INVITATION_FROM_EMAIL=convites@seudominio.com.br
INVITATION_FROM_NAME=Seu App
